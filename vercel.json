{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "www.stackcleaner.com" }],
      "destination": "https://stackcleaner.com/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.stackcleaner.com" }],
      "destination": "https://stackcleaner.com/:path*",
      "permanent": true
    }
  ]
}
